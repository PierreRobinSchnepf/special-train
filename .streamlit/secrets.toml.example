# Secrets template for the dashboard deployment.
#
# LOCALLY: copy this file to `.streamlit/secrets.toml` ONLY if you want to
# test cloud mode (S3 reads + admin lock) on your machine. Without this file,
# the app runs in local mode (disk reads, every button active).
# `.streamlit/secrets.toml` is gitignored — never commit it.
#
# ON STREAMLIT COMMUNITY CLOUD: do NOT push a file; paste this content into
# "App settings → Secrets" (see docs/deployment.md).

# Password unlocking the write buttons (data refresh, live forecast) in the
# sidebar. Pick a long, private one.
admin_password = "change-me"

[s3]
# SSP Cloud (Onyxia) MinIO endpoint. Check the exact host under
# "My account → Storage connection" on your datalab.
endpoint_url = "https://minio.lab.sspcloud.fr"
aws_access_key_id = "YOUR_ACCESS_KEY"
aws_secret_access_key = "YOUR_SECRET_KEY"
# Session token: required with Onyxia's TEMPORARY credentials (they expire in
# ~7 days). Leave "" with a permanent MinIO service account (recommended for
# a durable deployment — see docs/deployment.md).
aws_session_token = ""
# Target bucket (often your SSP Cloud username) and root prefix.
bucket = "your-sspcloud-user"
prefix = "gas-dashboard"
