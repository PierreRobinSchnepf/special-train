# Modèle de secrets pour le déploiement du dashboard.
#
# EN LOCAL : copie ce fichier en `.streamlit/secrets.toml` UNIQUEMENT si tu veux
# tester le mode cloud (lecture S3 + verrou admin) sur ta machine. Sans ce
# fichier, l'app tourne en mode local (lecture disque, tous boutons actifs).
# `.streamlit/secrets.toml` est gitignoré — ne le commite jamais.
#
# SUR STREAMLIT COMMUNITY CLOUD : ne pousse PAS de fichier ; colle ce contenu
# dans « App settings → Secrets » (cf. DEPLOY.md).

# Mot de passe qui débloque les boutons d'écriture (actualisation, prévision
# réelle live) dans la barre latérale. Choisis-en un long et privé.
admin_password = "change-moi"

[s3]
# Endpoint MinIO de SSP Cloud (Onyxia). Vérifie l'hôte exact dans
# « Mon compte → Connexion au stockage » sur ton datalab.
endpoint_url = "https://minio.lab.sspcloud.fr"
aws_access_key_id = "TON_ACCESS_KEY"
aws_secret_access_key = "TON_SECRET_KEY"
# Jeton de session : nécessaire si tu utilises les identifiants TEMPORAIRES
# d'Onyxia (ils expirent ~7 j). Laisse "" si tu utilises un compte de service
# MinIO permanent (recommandé pour un déploiement durable — cf. DEPLOY.md).
aws_session_token = ""
# Bucket cible (souvent ton nom d'utilisateur SSP Cloud) et préfixe racine.
bucket = "ton-user-sspcloud"
prefix = "gaz-dashboard"
